# Anthropic API Key for chat and summarization
# Get from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# NOTE: This app uses in-memory storage for feedback and summaries
# Data persists during the session but is cleared on server restart
# To use persistent storage, replace lib/db.ts with MongoDB, Chroma, Supabase, etc.

# Public API URL (used by frontend)
NEXT_PUBLIC_API_URL=http://localhost:3000

# PostHog Analytics (optional)
# Get from: https://posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
