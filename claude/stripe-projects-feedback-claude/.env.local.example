# MongoDB Connection
# For Railway MongoDB: Get connection string from Railway dashboard
# Format: mongodb+srv://username:password@host/database
MONGODB_URI=mongodb://localhost:27017/feedback

# OpenAI API Key for chat and summarization
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Public API URL (used by frontend)
NEXT_PUBLIC_API_URL=http://localhost:3000

# PostHog Analytics (optional)
# Get from: https://posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
