{
  "name": "stripe-projects-feedback",
  "version": "1.0.0",
  "description": "Feedback collection and chat app for Stripe Projects improvements",
  "scripts": {
    "dev": "next dev",
    "dev:docker": "docker-compose up",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "docker:build": "docker build -t stripe-feedback:latest .",
    "docker:run": "docker run -p 3000:3000 --env-file .env.local stripe-feedback:latest",
    "stripe:catalog": "stripe projects catalog",
    "stripe:add-services": "stripe projects add vercel/project && stripe projects add railway/mongo && stripe projects add posthog/analytics",
    "stripe:env-pull": "stripe projects env --pull",
    "stripe:env-push": "stripe projects env --push"
  },
  "dependencies": {
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "axios": "^1.6.0",
    "openai": "^4.0.0",
    "mongodb": "^6.0.0",
    "dotenv": "^16.0.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^9.0.0"
  }
}
